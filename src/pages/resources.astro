---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDocMarkdown, getStandaloneDoc, renderMarkdown } from "../lib/content";

const doc = getStandaloneDoc("resources.md", "/resources/", "学习资源索引");
const html = renderMarkdown(getDocMarkdown(doc));
---

<BaseLayout title={doc.title} description={doc.description}>
  <article class="document-layout">
    <header class="page-header">
      <p class="eyebrow">Resources</p>
      <h1>{doc.title}</h1>
      <p>{doc.description}</p>
    </header>
    <div class="markdown-body" set:html={html} />
  </article>
</BaseLayout>
